--- !u!114 &7775999159100387320
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7775999158574852181}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5776d334d35ed949b4189d440c96b06, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  chatText: {fileID: 7775999158438569267}
  chatArray1:
  - 'Hi, A few months have passed since we got magically teleported to Italy and
    now we got a place of our own. It''s time for us to make our dreams come true.

'
  - With your help I can finally achieve what I always dreamed of, making it into
    reality.
  - "Let\u2019s see what life has in store for me. Are you ready?"
  chatArray2:
  - ' Look at that new pathway! Looks good. Thank you.'
  chatArray3:
  - Wow! A Mansion, finally a place where me and my friends can stay together.
  chatArray4:
  - Ah! A pool, a place to relax and get sun tan.
  - '*Yawns* ah it''s too late, let''s sleep for today and see what tomorrow brings.'
  speedPerCharactor: 0.05
  chatAnim: {fileID: 7775999158208157363}
  tapAnim: {fileID: 5654458032663639477}
